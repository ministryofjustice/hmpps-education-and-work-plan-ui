<h2 class="govuk-heading-m">Skills and interests</h2>

<dl class="govuk-summary-list govuk-!-margin-bottom-8">

  <div class="govuk-summary-list__row">
    <dt class="govuk-summary-list__key govuk-!-width-one-quarter">
      Skills confidence level
    </dt>
    <dd class="govuk-summary-list__value" data-qa="employability-skills">
      {% for employabilitySkill in inductionDto.employabilitySkills %}
        <div data-qa="employability-skill-{{ employabilitySkill.employabilitySkillType }}">
          {% if employabilitySkill.employabilitySkillType === 'NONE' %}
            {{ employabilitySkill.employabilitySkillType | formatEmployabilitySkill }}
          {% else %}
            {{ employabilitySkill.employabilitySkillType | formatEmployabilitySkill }}<span data-qa="employability-skill-rating-{{ employabilitySkill.employabilitySkillRating }}">: {{ employabilitySkill.employabilitySkillRating | formatEmployabilitySkillRating }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </dd>
    <dd class="govuk-summary-list__actions">
      <a class="govuk-link" href="employability-skills?submitToCheckAnswers=true" data-qa="employabilitySkillsLink">
        Change<span class="govuk-visually-hidden"> employability skills</span>
      </a>
    </dd>
  </div>

  <div class="govuk-summary-list__row">
    <dt class="govuk-summary-list__key govuk-!-width-one-quarter">
      Interests
    </dt>
    <dd class="govuk-summary-list__value" data-qa="personalInterests">
      {% for item in inductionDto.personalSkillsAndInterests.interests %}
        <div data-qa="personalInterests-{{ item.interestType }}">{{ item.interestType | formatPersonalInterest }}{{ ' - ' + item.interestTypeOther if item.interestType === 'OTHER' }}{{ ',' if inductionDto.personalSkillsAndInterests.interests.length !== loop.index }}</div>
      {% endfor %}
    </dd>
    <dd class="govuk-summary-list__actions">
      <a class="govuk-link" href="personal-interests?submitToCheckAnswers=true" data-qa="personalInterestsLink">
        Change<span class="govuk-visually-hidden"> interests</span>
      </a>
    </dd>
  </div>
</dl>
